# Copy this file to .env.local (preferred) or .env and fill values.

# Absolute path to Firebase service account JSON
FIREBASE_SERVICE_ACCOUNT=/absolute/path/to/serviceAccountKey.json

# Firebase Realtime Database URL
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.asia-southeast1.firebasedatabase.app

# Optional node/path to write under
FIREBASE_NODE=sensor_data

# Optional periodic sync interval in seconds
# Set 0 to disable periodic sync
FIREBASE_SYNC_INTERVAL_SEC=60

# Optional one-shot upload when ./start runs
# Set 1 to run CANCOM/convert_and_upload.py in background on startup
RUN_FIREBASE_UPLOAD_ON_START=0

# Optional explicit SQLite path for one-shot upload script
# Defaults to new-type/Sensor_data.db when omitted
# SQLITE_DB_PATH=/absolute/path/to/Sensor_data.db
